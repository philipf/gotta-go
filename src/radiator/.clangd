# clangd config for the radiator firmware.
#
# compile_commands.json (generated by gen_compile_commands.py from the
# arduino-cli build) invokes the real device compiler, xtensa-esp32s3-elf-gcc,
# with GCC/Xtensa-specific flags. clangd parses with clang, which rejects those
# flags. Strip them so editor diagnostics aren't polluted — the device build
# (arduino-cli + gcc, ADR-0006) is unaffected; this only shapes what clangd sees.
#
# This handles the unknown-flag errors. Resolving the Xtensa sysroot headers
# (e.g. machine/endian.h) additionally needs clangd launched with
#   --query-driver=<path to>/bin/xtensa-esp32*-elf-*
# which is a per-machine editor setting, not config that belongs in the repo.
CompileFlags:
  Remove:
    - -mlongcalls
    - -fno-tree-switch-conversion
    - -fstrict-volatile-bitfields
